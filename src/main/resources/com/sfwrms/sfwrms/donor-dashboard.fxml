<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sfwrms.sfwrms.DonorDashboardController"
            style="-fx-background-color: #f0f7f0;">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #27ae60; -fx-padding: 14 20 14 20;">
            <Label text="🍱 SFWRMS — Donor Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUserName"
                   style="-fx-text-fill: #d5f5e3; -fx-font-size: 14;"/>
            <Button fx:id="btnLogout" text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: white; -fx-text-fill: #27ae60;
                           -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Hub Buttons -->
    <center>
        <VBox alignment="CENTER" spacing="28" style="-fx-padding: 60;">
            <Label text="What would you like to do?"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <HBox alignment="CENTER" spacing="30">
                <!-- UC01 — Log Surplus Food -->
                <VBox alignment="CENTER" spacing="8" prefWidth="260" prefHeight="180"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #27ae60; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 24; -fx-cursor: hand;"
                      onMouseClicked="#handleAddDonation">
                    <Label text="📝" style="-fx-font-size: 36;"/>
                    <Label text="Log Surplus Food" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>

                <!-- UC02 — Modify Donation -->
                <VBox alignment="CENTER" spacing="8" prefWidth="260" prefHeight="180"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #2980b9; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 24; -fx-cursor: hand;"
                      onMouseClicked="#handleEditDonation">
                    <Label text="✏️" style="-fx-font-size: 36;"/>
                    <Label text="Modify Donation" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                </VBox>
            </HBox>

            <HBox alignment="CENTER" spacing="30">
                <!-- UC03 — Delete Donation -->
                <VBox alignment="CENTER" spacing="8" prefWidth="260" prefHeight="180"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #e74c3c; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 24; -fx-cursor: hand;"
                      onMouseClicked="#handleDeleteDonation">
                    <Label text="🗑️" style="-fx-font-size: 36;"/>
                    <Label text="Delete Donation" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #e74c3c;"/>
                </VBox>

                <!-- UC04 — Track Donation Status -->
                <VBox alignment="CENTER" spacing="8" prefWidth="260" prefHeight="180"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #8e44ad; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 24; -fx-cursor: hand;"
                      onMouseClicked="#handleTrackDonations">
                    <Label text="📊" style="-fx-font-size: 36;"/>
                    <Label text="Track Donation Status" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sfwrms.sfwrms.DonorDonationsController"
            style="-fx-background-color: #f5f5f5;">

    <!-- Header with action buttons in top-right -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #27ae60; -fx-padding: 14 20 14 20;">
                <Label fx:id="lblTitle" text="My Donations"
                       style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnAction" text="Action" onAction="#handleAction"
                        prefHeight="34"
                        style="-fx-background-color: #f1c40f; -fx-text-fill: #2c3e50;
                               -fx-font-weight: bold; -fx-font-size: 13;
                               -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Button text="Refresh" onAction="#handleRefresh"
                        prefHeight="34"
                        style="-fx-background-color: white; -fx-text-fill: #27ae60;
                               -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Button fx:id="btnBack" text="Back" onAction="#handleBack"
                        prefHeight="34"
                        style="-fx-background-color: white; -fx-text-fill: #27ae60;
                               -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ecf0f1; -fx-padding: 6 20 6 20;">
                <Label fx:id="lblInstruction" style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" style="-fx-text-fill: #555; -fx-font-size: 12;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Donations Table -->
    <center>
        <VBox spacing="0" style="-fx-padding: 10 16 16 16;">
            <TableView fx:id="tblDonations" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 6;">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"         prefWidth="55"/>
                    <TableColumn fx:id="colFoodType"  text="Food Type"  prefWidth="160"/>
                    <TableColumn fx:id="colQuantity"  text="Qty"       prefWidth="85"/>
                    <TableColumn fx:id="colStatus"    text="Status"     prefWidth="110"/>
                    <TableColumn fx:id="colExpiry"    text="Expiry"     prefWidth="170"/>
                    <TableColumn fx:id="colLocation"  text="Location"   prefWidth="200"/>
                    <TableColumn fx:id="colUrgency"   text="Urgency"    prefWidth="100"/>
                </columns>
                <placeholder><Label text="No donations found."/></placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>

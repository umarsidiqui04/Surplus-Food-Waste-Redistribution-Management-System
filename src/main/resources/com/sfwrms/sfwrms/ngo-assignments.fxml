<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sfwrms.sfwrms.NGOAssignmentsController"
            style="-fx-background-color: #f5f5f5;">

    <!-- Header - VIEW ONLY (no action buttons except Refresh and Back) -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="12"
                  style="-fx-background-color: #1a5276; -fx-padding: 14 20 14 20;">
                <Label text="My Assignments — View Status"
                       style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="Refresh" onAction="#handleRefresh"
                        prefHeight="34"
                        style="-fx-background-color: white; -fx-text-fill: #1a5276;
                               -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Button fx:id="btnBack" text="Back" onAction="#handleBack"
                        prefHeight="34"
                        style="-fx-background-color: white; -fx-text-fill: #1a5276;
                               -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
            </HBox>
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #ecf0f1; -fx-padding: 6 20 6 20;">
                <Label text="Track the status of your accepted assignments here. Use Assign Driver from the dashboard to assign drivers."
                       style="-fx-font-size: 12; -fx-text-fill: #555;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" style="-fx-text-fill: #555; -fx-font-size: 12;"/>
            </HBox>
        </VBox>
    </top>

    <center>
        <VBox spacing="0" style="-fx-padding: 10 16 16 16;">
            <TableView fx:id="tblAssignments" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 6;">
                <columns>
                    <TableColumn fx:id="colId"       text="#"          prefWidth="50"/>
                    <TableColumn fx:id="colFoodType"  text="Food Type"  prefWidth="140"/>
                    <TableColumn fx:id="colQty"       text="Qty"      prefWidth="75"/>
                    <TableColumn fx:id="colLocation"  text="Location"   prefWidth="165"/>
                    <TableColumn fx:id="colExpiry"    text="Expires"    prefWidth="140"/>
                    <TableColumn fx:id="colDonor"     text="Donor"      prefWidth="120"/>
                    <TableColumn fx:id="colDriver"    text="Driver"     prefWidth="120"/>
                    <TableColumn fx:id="colStatus"    text="Status"     prefWidth="100"/>
                    <TableColumn fx:id="colDelivery"  text="Delivery"   prefWidth="90"/>
                </columns>
                <placeholder><Label text="No assignments found for your NGO."/></placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>

<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sfwrms.sfwrms.NGODashboardController"
            style="-fx-background-color: #eaf2f8;">

    <!-- Header -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-background-color: #1a5276; -fx-padding: 14 20 14 20;">
            <Label text="🏢 SFWRMS — NGO Dashboard"
                   style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="lblUserName"
                   style="-fx-text-fill: #aed6f1; -fx-font-size: 14;"/>
            <Button fx:id="btnLogout" text="Logout" onAction="#handleLogout"
                    style="-fx-background-color: white; -fx-text-fill: #1a5276;
                           -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
        </HBox>
    </top>

    <!-- Hub Buttons -->
    <center>
        <VBox alignment="CENTER" spacing="28" style="-fx-padding: 50;">
            <Label text="NGO Operations"
                   style="-fx-font-size: 22; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>

            <!-- Row 1 -->
            <HBox alignment="CENTER" spacing="24">
                <!-- UC05 — View Meals Saved -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="160"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #27ae60; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#handleViewMealsSaved">
                    <Label text="🍽️" style="-fx-font-size: 32;"/>
                    <Label text="View Meals Saved" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #27ae60;"/>
                </VBox>

                <!-- UC06 — Generate Report -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="160"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #8e44ad; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#handleGenerateReport">
                    <Label text="📊" style="-fx-font-size: 32;"/>
                    <Label text="Generate Report" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #8e44ad;"/>
                </VBox>

                <!-- UC07 + UC09 — View Available Donations (Accept/Reject) -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="160"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #2980b9; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#handleViewDonations">
                    <Label text="🔍" style="-fx-font-size: 32;"/>
                    <Label text="View Donations" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #2980b9;"/>
                </VBox>
            </HBox>

            <!-- Row 2 -->
            <HBox alignment="CENTER" spacing="24">
                <!-- View Assignments (track accepted ones) -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="160"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #e67e22; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#handleViewAssignments">
                    <Label text="📋" style="-fx-font-size: 32;"/>
                    <Label text="View Assignments" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #e67e22;"/>
                </VBox>

                <!-- UC10 — Assign Driver -->
                <VBox alignment="CENTER" spacing="8" prefWidth="220" prefHeight="160"
                      style="-fx-background-color: white; -fx-background-radius: 12;
                             -fx-border-color: #7d3c98; -fx-border-radius: 12; -fx-border-width: 2;
                             -fx-padding: 20; -fx-cursor: hand;"
                      onMouseClicked="#handleAssignDriver">
                    <Label text="🚗" style="-fx-font-size: 32;"/>
                    <Label text="Assign Driver" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #7d3c98;"/>
                </VBox>
            </HBox>
        </VBox>
    </center>
</BorderPane>

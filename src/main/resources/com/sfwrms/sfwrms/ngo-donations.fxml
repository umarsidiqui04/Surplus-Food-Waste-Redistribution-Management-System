<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.sfwrms.sfwrms.NGODonationsController"
            style="-fx-background-color: #f5f5f5;">

    <!-- Header with Accept/Reject buttons in top-right -->
    <top>
        <VBox>
            <HBox alignment="CENTER_LEFT" spacing="10"
                  style="-fx-background-color: #1a5276; -fx-padding: 14 20 14 20;">
                <Label text="Available Donations"
                       style="-fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: bold;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button fx:id="btnAccept" text="Accept" onAction="#handleAccept"
                        prefHeight="34"
                        style="-fx-background-color: #27ae60; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13;
                               -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Button fx:id="btnReject" text="Reject" onAction="#handleReject"
                        prefHeight="34"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13;
                               -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Button text="Details" onAction="#handleViewDetails"
                        prefHeight="34"
                        style="-fx-background-color: #2980b9; -fx-text-fill: white;
                               -fx-font-size: 13;
                               -fx-background-radius: 5; -fx-cursor: hand;"/>
                <Button fx:id="btnBack" text="Back" onAction="#handleBack"
                        prefHeight="34"
                        style="-fx-background-color: white; -fx-text-fill: #1a5276;
                               -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;"/>
            </HBox>
            <!-- Filter Bar -->
            <HBox spacing="10" alignment="CENTER_LEFT"
                  style="-fx-background-color: #ecf0f1; -fx-padding: 8 20 8 20;">
                <Label text="Location:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="tfLocationFilter" promptText="e.g. Karachi" prefWidth="140" prefHeight="30"/>
                <Label text="Food Type:" style="-fx-font-weight: bold;"/>
                <TextField fx:id="tfFoodTypeFilter" promptText="e.g. Rice" prefWidth="140" prefHeight="30"/>
                <Label text="Sort:" style="-fx-font-weight: bold;"/>
                <ComboBox fx:id="cbSort" prefWidth="200"/>
                <Button text="Filter" onAction="#handleFilter"
                        prefHeight="30"
                        style="-fx-background-color:#2980b9; -fx-text-fill:white;
                               -fx-background-radius:5; -fx-cursor:hand;"/>
                <Button text="Clear" onAction="#handleClearFilter"
                        prefHeight="30"
                        style="-fx-background-color:#7f8c8d; -fx-text-fill:white;
                               -fx-background-radius:5; -fx-cursor:hand;"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="lblStatus" style="-fx-text-fill: #555; -fx-font-size: 12;"/>
            </HBox>
        </VBox>
    </top>

    <!-- Donations Table -->
    <center>
        <VBox spacing="0" style="-fx-padding: 10 16 16 16;">
            <TableView fx:id="tblDonations" VBox.vgrow="ALWAYS"
                       style="-fx-background-color: white; -fx-background-radius: 6;">
                <columns>
                    <TableColumn fx:id="colId"       text="ID"          prefWidth="55"/>
                    <TableColumn fx:id="colFoodType"  text="Food Type"   prefWidth="150"/>
                    <TableColumn fx:id="colQty"       text="Qty"       prefWidth="80"/>
                    <TableColumn fx:id="colLocation"  text="Location"    prefWidth="180"/>
                    <TableColumn fx:id="colPrepTime"  text="Prepared"    prefWidth="140"/>
                    <TableColumn fx:id="colExpiry"    text="Expires"     prefWidth="140"/>
                    <TableColumn fx:id="colUrgency"   text="Urgency"     prefWidth="80"/>
                    <TableColumn fx:id="colDecision"  text="Decision"    prefWidth="100"/>
                </columns>
                <placeholder><Label text="No donations match the current filter."/></placeholder>
            </TableView>
        </VBox>
    </center>
</BorderPane>
